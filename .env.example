# Google Cloud configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Path to Service Account JSON key
# If not set, the agent will use Application Default Credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS_PATH=path/to/service-account.json
# PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@host:port/dbname?sslmode=require
